{
    "name": "barashka",
    "version": "1.0.0",
    "description": "A minimalist music player for managing your local media library with streaming capabilities",
    "type": "module",
    "main": "sw.js",
    "scripts": {
        "dev": "vite",
        "dev:desktop": "node scripts/dev-runner.js & vite",
        "build": "vite build --mode neutralino && bun x neu build",
        "build:web": "vite build",
        "build:check": "npm run lint && npm run build:web",
        "predeploy": "npm run build:web",
        "deploy": "gh-pages -d dist",
        "preview": "vite preview",
        "lint:js": "eslint .",
        "lint:css": "stylelint \"**/*.css\"",
        "lint:html": "htmlhint \"**/*.html\" --ignore=\"dist/**,legacy/**,node_modules/**\"",
        "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "echo \"Error: no test specified\" && exit 1",
        "postbuild": "node -e \"const fs = require('fs'); const path = require('path'); const src = 'extensions'; const dest = path.join('dist', 'Barashka', 'extensions'); if (fs.existsSync(src)) { fs.mkdirSync(dest, { recursive: true }); fs.cpSync(src, dest, { recursive: true }); console.log('Extensions manually copied to ' + dest); }\""
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Bebrowskiy/barashka.git"
    },
    "keywords": [
        "music-player",
        "music",
        "player",
        "streaming",
        "tidal",
        "qobuz",
        "pwa",
        "neutralinojs",
        "desktop-app",
        "monochrome-fork"
    ],
    "author": "Bebrowskiy",
    "license": "Apache-2.0",
    "bugs": {
        "url": "https://github.com/Bebrowskiy/barashka/issues"
    },
    "homepage": "https://github.com/Bebrowskiy/barashka#readme",
    "dependencies": {
        "@ffmpeg/ffmpeg": "^0.12.15",
        "@ffmpeg/util": "^0.12.2",
        "@kawarp/core": "^1.1.1",
        "@neutralinojs/lib": "^6.5.0",
        "appwrite": "^23.0.0",
        "butterchurn": "^2.6.7",
        "butterchurn-presets": "^2.4.7",
        "cookie-session": "^2.1.1",
        "dashjs": "^5.1.1",
        "firebase": "^12.10.0",
        "jose": "^6.1.3",
        "npm": "^11.11.0",
        "pocketbase": "^0.26.8"
    },
    "devDependencies": {
        "@neutralinojs/neu": "^11.7.0",
        "eslint": "^9.39.3",
        "eslint-config-prettier": "^10.1.8",
        "gh-pages": "^6.3.0",
        "globals": "^17.4.0",
        "htmlhint": "^1.9.1",
        "miniflare": "^4.20260301.1",
        "prettier": "^3.8.1",
        "stylelint": "^16.26.1",
        "stylelint-config-standard": "^39.0.1",
        "stylelint-config-standard-scss": "^16.0.0",
        "vite": "^7.3.1",
        "vite-plugin-neutralino": "^1.0.3",
        "vite-plugin-pwa": "^1.2.0"
    },
    "overrides": {
        "sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.4.14",
        "source-map": "^0.7.4"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    }
}
