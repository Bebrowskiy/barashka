{
    "name": "barashka",
    "version": "1.0.0",
    "description": "A minimalist music player for managing your local media library with streaming capabilities",
    "type": "module",
    "main": "sw.js",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:web": "vite build",
        "build:check": "npm run lint && npm run build:web",
        "predeploy": "npm run build:web",
        "deploy": "gh-pages -d dist",
        "preview": "vite preview",
        "tauri": "tauri",
        "cap:sync": "npx cap sync",
        "cap:android": "npx cap open android",
        "cap:ios": "npx cap open ios",
        "lint:js": "eslint .",
        "lint:css": "stylelint \"**/*.css\"",
        "lint:html": "htmlhint \"**/*.html\" --ignore=\"dist/**,legacy/**,node_modules/**\"",
        "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Bebrowskiy/barashka.git"
    },
    "keywords": [
        "music-player",
        "music",
        "player",
        "streaming",
        "tidal",
        "qobuz",
        "pwa",
        "monochrome-fork"
    ],
    "author": "Bebrowskiy",
    "license": "Apache-2.0",
    "bugs": {
        "url": "https://github.com/Bebrowskiy/barashka/issues"
    },
    "homepage": "https://github.com/Bebrowskiy/barashka#readme",
    "dependencies": {
        "@capacitor/android": "^8.2.0",
        "@capacitor/core": "^8.2.0",
        "@capacitor/ios": "^8.2.0",
        "@ffmpeg/ffmpeg": "^0.12.15",
        "@ffmpeg/util": "^0.12.2",
        "@kawarp/core": "^1.1.1",
        "@tauri-apps/api": "^2.10.1",
        "appwrite": "^23.0.0",
        "butterchurn": "^2.6.7",
        "butterchurn-presets": "^2.4.7",
        "cookie-session": "^2.1.1",
        "dashjs": "^5.1.1",
        "firebase": "^12.10.0",
        "jose": "^6.1.3",
        "npm": "^11.11.0",
        "pocketbase": "^0.26.8"
    },
    "devDependencies": {
        "@capacitor/cli": "^8.2.0",
        "@tauri-apps/cli": "^2.10.1",
        "eslint": "^9.39.3",
        "eslint-config-prettier": "^10.1.8",
        "gh-pages": "^6.3.0",
        "globals": "^17.4.0",
        "htmlhint": "^1.9.1",
        "miniflare": "^4.20260301.1",
        "prettier": "^3.8.1",
        "stylelint": "^16.26.1",
        "stylelint-config-standard": "^39.0.1",
        "stylelint-config-standard-scss": "^16.0.0",
        "vite": "^7.3.1",
        "vite-plugin-pwa": "^1.2.0"
    },
    "overrides": {
        "sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.4.14",
        "source-map": "^0.7.4"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    }
}
