# ============================================================================
bin/
resources/tmp/
resources/app/
neutralinojs.log
*.exe
*.dmg
*.deb
*.rpm
*.AppImage

# ============================================================================
# ENVIRONMENT VARIABLES (CRITICAL - NEVER COMMIT)
# ============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
.env.*.private
*.env

# ============================================================================
# OPERATING SYSTEM
# ============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
@eaDir/

