logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# ============================================================================
# TESTING
# ============================================================================
coverage/
.nyc_output/
*.lcov
.jest/
test-results/
playwright-report/
test-report/
PROJECT_ANALYSIS.md

# ============================================================================
# TEMPORARY FILES
# ============================================================================
tmp/
temp/
*.tmp
*.temp
.cache/
.parcel-cache/

# ============================================================================
# PACKAGE LOCKS (keep one, ignore others)
# ============================================================================
# Uncomment based on your package manager:
# package-lock.json    # if using Yarn/Bun
# yarn.lock            # if using npm/Bun
# pnpm-lock.yaml       # if using npm/Yarn
# bun.lockb            # if using npm/Yarn

# ============================================================================
# VITE
# ============================================================================
*.local
.vite/
vite.config.*.timestamp-*

# ============================================================================
# EXTENSIONS BUILD FILES
