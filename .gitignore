# ============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
*.swo
*.swp
*.sublime-project
*.sublime-workspace
*.tmproj
*.jbproject
.project
.classpath
.cproject
*.iml
.vs/
*.code-workspace
.cache/

