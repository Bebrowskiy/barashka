# ============================================================================
# DEPENDENCIES
# ============================================================================
node_modules/
bun.lockb
bun.lock
.pnp.*
.yarn/*
!.yarn/patches/*.zip
!.yarn/plugins/*.js
!.yarn/releases/*.cjs
!.yarn/versions/*.yml

# ============================================================================
# BUILD OUTPUTS
# ============================================================================
dist/
build/
out/
.next/
.nuxt/

# ============================================================================
