{
    "applicationId": "com.barashka.app",
    "applicationName": "Barashka",
    "applicationIcon": "public/assets/appicon.png",
    "author": "Barashka",
    "description": "Barashka - Lossless music streaming",
    "version": "1.0.0",
    "defaultMode": "window",
    "documentRoot": "/dist",
    "url": "/neutralino_loader.html",
    "enableServer": true,
    "enableNativeAPI": true,
    "enableExtensions": true,
    "tokenSecurity": "none",
    "modes": {
        "window": {
            "title": "Barashka",
            "icon": "public/assets/appicon.png",
            "width": 1280,
            "height": 800,
            "minWidth": 800,
            "minHeight": 600,
            "center": true,
            "resizable": true,
            "hidden": false,
            "borderless": false,
            "enableInspector": true,
            "openInspectorOnStartup": false,
            "exitProcessOnClose": true
        }
    },
    "port": 5050,
    "cli": {
        "binaryName": "Barashka",
        "resourcesPath": "dist",
        "binaryVersion": "6.5.0",
        "clientVersion": "6.5.0",
        "outputPath": "dist/bin"
    },
    "extensions": [
        {
            "id": "js.neutralino.discordrpc",
            "commandLinux": "python3 \"${NL_PATH}/extensions/js.neutralino.discordrpc/bridge.py\"",
            "commandMac": "python3 \"${NL_PATH}/extensions/js.neutralino.discordrpc/bridge.py\"",
            "commandWindows": "powershell.exe -ExecutionPolicy Bypass -File \"${NL_PATH}/extensions/js.neutralino.discordrpc/bridge.ps1\""
        }
    ],
    "nativeAllowList": [
        "app.*",
        "window.*",
        "extensions.*",
        "events.*",
        "os.*",
        "filesystem.*",
        "debug.*",
        "storage.*",
        "computer.*",
        "clipboard.*",
        "updater.*"
    ]
}
